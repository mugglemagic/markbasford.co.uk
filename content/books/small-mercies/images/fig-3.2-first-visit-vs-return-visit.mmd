    style R1 fill:#ecfdf5,stroke:#059669,color:#1a1a2e
    style R2 fill:#ecfdf5,stroke:#059669,color:#1a1a2e
    style R3 fill:#ecfdf5,stroke:#059669,color:#1a1a2e
