graph TD
    subgraph First["First Visit — Orientation"]
        direction TB
        F1["Reduce overwhelm<br/><em>Show one clear next step</em>"]
        F2["Introduce vocabulary<br/><em>Name things the user<br/>will need to know</em>"]
        F3["Build confidence<br/><em>Quick win within<br/>first 60 seconds</em>"]
        F1 --> F2 --> F3
    end

    subgraph Return["Return Visit — Recognition"]
        direction TB
        R1["Acknowledge the user<br/><em>Name, time of day,<br/>context</em>"]
        R2["Show what changed<br/><em>Updates, comments,<br/>activity since last visit</em>"]
        R3["Resume context<br/><em>Where they left off,<br/>in-progress work</em>"]
        R1 --> R2 --> R3
    end

